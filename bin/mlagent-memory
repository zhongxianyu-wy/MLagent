#!/usr/bin/env python3
"""mlagent-memory plugin entry wrapper.

Development: if a sibling ``.venv/bin/python`` exists, re-exec into it so the CLI's
third-party dependencies resolve. Production: install the package
(``pip install -e .``) so the ``mlagent-memory`` console script and its dependencies
are available; this wrapper then imports ``mlagent_memory`` from the plugin root.
"""
import os
import sys
from pathlib import Path

_PLUGIN_ROOT = Path(__file__).resolve().parent.parent
_VENV_PY = _PLUGIN_ROOT / ".venv" / "bin" / "python"

if _VENV_PY.exists() and os.path.realpath(sys.executable) != os.path.realpath(str(_VENV_PY)):
    os.execv(str(_VENV_PY), [str(_VENV_PY), str(Path(__file__).resolve()), *sys.argv[1:]])

sys.path.insert(0, str(_PLUGIN_ROOT))

from mlagent_memory.cli import main

if __name__ == "__main__":
    main()
